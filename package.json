{
  "name": "@tagit/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for TAGIT ERC-8004 agent contracts on OP Sepolia",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./a2a": {
      "import": "./dist/a2a/index.js",
      "types": "./dist/a2a/index.d.ts"
    },
    "./cli": {
      "import": "./dist/cli/index.js"
    }
  },
  "bin": {
    "tagit": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist",
    "docs": "typedoc"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "viem": "^2.23.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "lint-staged": "^17.0.7",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "lint-staged": {
    "*.ts": "bash -c 'tsc -p tsconfig.build.json --noEmit'"
  }
}
